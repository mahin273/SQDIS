POSTGRES_USER=your_db_username
POSTGRES_PASSWORD=your_db_password
POSTGRES_DB=sqdis_db
POSTGRES_PORT=5432
DATABASE_URL="postgresql://your_db_username:your_db_password@localhost:5435/sqdis_db"

# SMTP Configuration (for email verification)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password
SMTP_FROM=your_email@gmail.com
APP_BASE_URL=http://localhost:3000

# Generate with: openssl rand -base64 64
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Google OAuth 2.0
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# GitHub OAuth
# Get from: https://github.com/settings/developers
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_CALLBACK_URL=http://localhost:3000/api/auth/github/callback

# Encryption (for GitHub PAT storage)
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=your_encryption_key_32bytes

# Service Ports
BACKEND_PORT=3000
FRONTEND_PORT=5173
ML_SERVICE_PORT=8000
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001

# Frontend URLs
VITE_API_URL=http://localhost:3000/api
VITE_WS_URL=ws://localhost:3000
FRONTEND_URL=http://localhost:5173

# ML Service
ML_SERVICE_URL=http://ml-service:8000
MLFLOW_TRACKING_URI=http://localhost:5000

# Monitoring (Grafana)
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# Bcrypt Configuration
BCRYPT_COST_FACTOR=12

# Rate Limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# Cache TTL (seconds)
CACHE_TTL=3600

# GitHub Webhook
WEBHOOK_BASE_URL=https://your-ngrok-or-domain.ngrok-free.app
WEBHOOK_SECRET=your_webhook_secret_here

# File Upload
MAX_FILE_SIZE=104857600
UPLOAD_DIR=./uploads

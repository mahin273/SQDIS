  "info": {
    "title": "My API",
    "description": "API documentation",
    "version": "1.0",
    "contact": {}
  },
  "tags": [
    {
      "name": "api",
      "description": ""
    }
  ],
  "servers": [],
  "components": {
    "schemas": {
      "RegisterDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "description": "User email address",
            "example": "user@example.com"
          },
          "password": {
            "type": "string",
            "description": "User password  (min 8 char,must contain uppercase,lowercase, and num)",
            "example": "SecurePass123",
            "minLength": 8,
            "maxLength": 128
          },
          "name": {
            "type": "string",
            "description": "User display",
            "example": "Mahin Khan",
            "minLength": 1,
            "maxLength": 100
          }
        },
        "required": [
          "email",
          "password",
          "name"
        ]
      },
      "LoginDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "description": "User email address",
            "example": "user@example.com"
          },
          "password": {
            "type": "string",
            "description": "User password",
            "example": "SecurePass123"
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "RefreshDto": {
        "type": "object",
        "properties": {
          "refreshToken": {
            "type": "string",
            "description": "Refresh token for obtaining new access token",
            "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
          }
        },
        "required": [
          "refreshToken"
        ]
      },
      "ForgotPasswordDto": {
        "type": "object",
        "properties": {
          "identifier": {
            "type": "string",
            "description": "Email address or username (email alias) associated with the account",
            "example": "user@example.com"
          }
        },
        "required": [
          "identifier"
        ]
      },
      "ResetPasswordDto": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string",
            "description": "Password reset token received via email",
            "example": "abc123def456..."
          },
          "newPassword": {
            "type": "string",
            "description": "New password (min 8 characters, must contain uppercase, lowercase, and number)",
            "example": "NewSecurePass123",
            "minLength": 8,
            "maxLength": 128
          }
        },
        "required": [
          "token",
          "newPassword"
        ]
      },
      "SwitchOrganizationDto": {
        "type": "object",
        "properties": {
          "organizationId": {
            "type": "string",
            "description": "ID of the organization to switch to",
            "example": "123e4567-e89b-12d3-a456-426614174000"
          }
        },
        "required": [
          "organizationId"
        ]
      },
      "CreateOrganizationDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Organization name",
            "example": "SQDIS",
            "minLength": 2,
            "maxLength": 100
          },
          "slug": {
            "type": "string",
            "description": "Organization slug (alphanumeric with hyphens only)",
            "example": "sqdis",
            "minLength": 2,
            "maxLength": 50
          }
        },
        "required": [
          "name",
          "slug"
        ]
      },
      "UpdateOrganizationDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Organization name",
            "example": "SQDIS",
            "minLength": 2,
            "maxLength": 100
          },
          "slug": {
            "type": "string",
            "description": "Organization slug (alphanumeric with hyphens only)",
            "example": "sqdis",
            "minLength": 2,
            "maxLength": 50
          },
          "logoUrl": {
            "type": "string",
            "description": "Organization logo URL",
            "example": "https://example.com/logo.png"
          }
        },
        "required": [
          "name"
        ]
      },
      "InviteMemberDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "description": "Email address of the person to invite",
            "example": "newmember@example.com"
          }
        },
        "required": [
          "email"
        ]
      },
      "UpdateMemberRoleDto": {
        "type": "object",
        "properties": {
          "role": {
            "type": "string",
            "description": "New role for the member",
            "enum": [
              "OWNER",
              "ADMIN",
              "TEAM_LEAD",
              "DEVELOPER"
            ],
            "example": "ADMIN"
          }
        },
        "required": [
          "role"
        ]
      },
      "ExportAuditLogsDto": {
        "type": "object",
        "properties": {
          "format": {
            "type": "string",
            "description": "Export format",
            "enum": [
              "CSV",
              "JSON"
            ]
          },
          "userId": {
            "type": "string",
            "description": "Filter by user ID"
          },
          "action": {
            "description": "Filter by action type",
            "type": "array",
            "items": {
              "type": "array"
            }
          },
          "resourceType": {
            "type": "string",
            "description": "Filter by resource type"
          },
          "resourceId": {
            "type": "string",
            "description": "Filter by resource ID"
          },
          "startDate": {
            "type": "string",
            "description": "Filter by start date (ISO 8601)"
          },
          "endDate": {
            "type": "string",
            "description": "Filter by end date (ISO 8601)"
          },
          "severity": {
            "type": "string",
            "description": "Filter by severity",
            "enum": [
              "LOW",
              "MEDIUM",
              "HIGH",
              "CRITICAL"
            ]
          }
        },
        "required": [
          "format"
        ]
      },
      "UpdateRetentionPolicyDto": {
        "type": "object",
        "properties": {
          "defaultRetentionDays": {
            "type": "number",
            "description": "Default retention period in days (minimum 90)",
            "example": 365,
            "minimum": 90
          },
          "actionSpecificRetention": {
            "type": "object",
            "description": "Action-specific retention periods (in days)",
            "example": {
              "LOGIN": 180,
              "PERMISSION_CHECK": 90,
              "ROLE_CHANGE": 730
            }
          }
        },
        "required": [
          "defaultRetentionDays"
        ]
      },
      "GenerateComplianceReportDto": {
        "type": "object",
        "properties": {
          "reportType": {
            "type": "string",
            "description": "Type of compliance report to generate",
            "enum": [
              "SOC2",
              "GDPR",
              "HIPAA"
            ],
            "example": "SOC2"
          },
          "startDate": {
            "type": "string",
            "description": "Start date for the report period (ISO 8601 format)",
            "example": "2024-01-01T00:00:00Z"
          },
          "endDate": {
            "type": "string",
            "description": "End date for the report period (ISO 8601 format)",
            "example": "2024-12-31T23:59:59Z"
          }
        },
        "required": [
          "reportType"
        ]
      }
    }
  }
}